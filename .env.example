# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/pricing_calculator

# WebberStop API Configuration
WEBBER_STOP_ADMIN_API_KEY=your_admin_api_key_here

# Google reCAPTCHA Configuration
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Server Configuration
NODE_ENV=development
PORT=5000

# Logging Configuration
LOG_LEVEL=info  # Options: debug, info, warn, error

# Session Configuration (if using sessions)
SESSION_SECRET=your_session_secret_here

# Optional: Rate Limiting Configuration
# These can override defaults in middleware/rateLimiter.ts
# API_RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# API_RATE_LIMIT_MAX=100
# QUOTE_RATE_LIMIT_WINDOW_MS=3600000  # 1 hour
# QUOTE_RATE_LIMIT_MAX=10
